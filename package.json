{
  "name": "ftp-uploader",
  "version": "1.0.0-beta",
  "description": "FTP/SFTP自动上传桌面应用",
  "main": ".vite/main/index.js",
  "author": "liguorui",
  "license": "MIT",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:mac": "electron-vite build && electron-forge make --platform darwin",
    "make:win": "electron-vite build && electron-forge make --platform win32",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.0",
    "antd": "^5.15.0",
    "basic-ftp": "^5.0.3",
    "chokidar": "^3.6.0",
    "dayjs": "^1.11.0",
    "electron-log": "^5.4.4",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "fast-glob": "^3.3.0",
    "minimatch": "^9.0.3",
    "nanoid": "^5.0.0",
    "node-cron": "^3.0.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.22.0",
    "ssh2-sftp-client": "^9.1.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.3.0",
    "@electron-forge/maker-dmg": "^7.3.0",
    "@electron-forge/maker-squirrel": "^7.3.0",
    "@electron-forge/maker-zip": "^7.3.0",
    "@electron-forge/plugin-vite": "^7.3.0",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2-sftp-client": "^9.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "appdmg": "^0.6.6",
    "electron": "^30.0.0",
    "electron-vite": "^2.1.0",
    "typescript": "^5.4.0",
    "vite": "^5.1.0"
  }
}
